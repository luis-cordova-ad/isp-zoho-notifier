# Keycloak OAuth2 Resource Server
KEYCLOAK_ISSUER_URI=https://keycloak.isp.local/realms/isp
KEYCLOAK_JWK_SET_URI=https://keycloak.isp.local/realms/isp/protocol/openid-connect/certs

# Zoho CRM credentials (JAMAIS en clair en prod — K8s Secret)
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
ZOHO_API_BASE_URL=https://www.zohoapis.com
ZOHO_AUTH_URL=https://accounts.zoho.com
ZOHO_WEBHOOK_ENABLED=false

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Base de données (ProxySQL → MariaDB freeradius_db)
DB_HOST=localhost
DB_PORT=6033
DB_NAME=freeradius_db
DB_USER=isp_zoho_notifier
DB_PASSWORD=changeme

# Graylog GELF
GRAYLOG_GELF_HOST=graylog.graylog.svc.cluster.local
GRAYLOG_GELF_PORT=12201

# Spring
SPRING_PROFILES_ACTIVE=dev
KUBERNETES_NAMESPACE=local
