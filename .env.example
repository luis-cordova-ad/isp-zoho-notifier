# isp-zoho-notifier — variables d'environnement
# Copier ce fichier en .env et remplir les vraies valeurs.
# NEVER commit .env avec de vrais secrets.
#
# ── Sélecteur d'environnement ─────────────────────────────────────────────────
ENV=dev
KUBE_CONTEXT=kubernetes-admin@kubernetes

# ── Harbor Registry ──────────────────────────────────────────────────────────
HARBOR_REGISTRY=harbor.internal.korlu.com
HARBOR_USER=robot$robot-cicd-01
HARBOR_PASS=changeme
IMAGE_TAG=latest

# ── Application ────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── Keycloak OAuth2 Resource Server ──────────────────────────────────────────
KEYCLOAK_ISSUER_URI=https://iam.internal.korlu.com/realms/isp
KEYCLOAK_JWK_SET_URI=http://keycloak.isp-iam.svc.cluster.local/realms/isp/protocol/openid-connect/certs

# Zoho CRM credentials (JAMAIS en clair en prod — K8s Secret)
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
ZOHO_API_BASE_URL=https://www.zohoapis.com
ZOHO_AUTH_URL=https://accounts.zoho.com
ZOHO_WEBHOOK_ENABLED=false

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Base de données (ProxySQL → MariaDB freeradius_db)
DB_HOST=localhost
DB_PORT=6033
DB_NAME=freeradius_db
DB_USER=isp_zoho_notifier
DB_PASSWORD=changeme

# Graylog GELF
GRAYLOG_GELF_HOST=graylog.graylog.svc.cluster.local
GRAYLOG_GELF_PORT=12201

# ── Kubernetes ───────────────────────────────────────────────────────────────
# Namespace : isp-system (identique tous envs — défini dans Taskfile, pas ici)
